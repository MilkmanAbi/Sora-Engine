{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@sora/engine": ["../../packages/engine/src/index.ts"],
      "@shared/*": ["../../packages/engine/src/contract/*"]
    },
    "noEmit": true
  },
  "include": ["src/renderer/**/*", "src/preload/index.d.ts", "../../packages/engine/src/contract/**/*"]
}
